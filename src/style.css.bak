:root {
    color-scheme: light;
    --docs-bg: #f8fafc;
    --docs-surface: #ffffff;
    --docs-surface-muted: #f1f5f9;
    --docs-border: #dbe3ef;
    --docs-border-strong: #c5d0df;
    --docs-text: #0f172a;
    --docs-text-soft: #475569;
    --docs-text-muted: #64748b;
    --docs-primary: #f97316;
    --docs-primary-soft: #fff1e8;
    --docs-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    --docs-radius: 18px;
    --docs-radius-sm: 12px;
    --docs-font: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --docs-code: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
}

::selection {
    background: rgba(249, 115, 22, 0.18);
    color: var(--docs-text);
}

* {
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    margin: 0;
    font-family: var(--docs-font);
    color: var(--docs-text);
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
}

a {
    color: #0f5ad9;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}

a:focus-visible,
button:focus-visible {
    outline: 3px solid rgba(15, 90, 217, 0.28);
    outline-offset: 2px;
}

img {
    max-width: 100%;
    height: auto;
}

code,
pre {
    font-family: var(--docs-code);
}

.screen-reader-text {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
}

.docs-header {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(14px);
    background: rgba(248, 250, 252, 0.88);
    border-bottom: 1px solid rgba(219, 227, 239, 0.9);
}

.docs-header__inner,
.docs-footer__inner {
    width: min(1400px, calc(100% - 32px));
    margin: 0 auto;
}

.docs-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
}

.docs-header__brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
}

.docs-header__home img,
.docs-header__home svg {
    display: block;
    width: 160px;
    max-width: 40vw;
    height: auto;
}

.docs-header__home-fallback {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    font-weight: 800;
    color: var(--docs-text);
}

.docs-header__title {
    font-size: 1rem;
    font-weight: 700;
}

.docs-header__tagline {
    margin: 2px 0 0;
    color: var(--docs-text-muted);
    font-size: 0.92rem;
}

.docs-header__menu-button {
    display: none;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid var(--docs-border);
    background: var(--docs-surface);
    color: var(--docs-text);
    cursor: pointer;
}

.docs-header__menu-icon,
.docs-nav__toggle-icon {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
}

.docs-header__skip-link {
    padding: 10px 14px;
    border-radius: 999px;
    background: var(--docs-surface);
    border: 1px solid var(--docs-border);
    color: var(--docs-text-soft);
    font-size: 0.92rem;
}

.docs-header__skip-link:focus-visible {
    position: relative;
}

.docs-shell {
    width: min(1400px, calc(100% - 32px));
    margin: 26px auto 40px;
    display: grid;
    grid-template-columns: minmax(260px, 300px) minmax(0, 1fr) minmax(220px, 260px);
    gap: 24px;
    align-items: start;
    position: relative;
}

.docs-shell__overlay {
    display: none;
}

.docs-shell__sidebar,
.docs-shell__toc,
.docs-article {
    min-width: 0;
}

.docs-sidebar,
.docs-toc-panel,
.docs-article {
    background: var(--docs-surface);
    border: 1px solid var(--docs-border);
    border-radius: var(--docs-radius);
    box-shadow: var(--docs-shadow);
}

.docs-sidebar,
.docs-toc-panel {
    position: sticky;
    top: 88px;
}

.docs-sidebar__head,
.docs-toc-panel {
    padding: 18px;
}

.docs-sidebar__title,
.docs-toc-panel__title {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--docs-text-muted);
    font-weight: 700;
}

.docs-sidebar__description {
    margin: 8px 0 0;
    color: var(--docs-text-soft);
    line-height: 1.5;
    font-size: 0.95rem;
}

.docs-sidebar__body {
    border-top: 1px solid var(--docs-border);
    padding: 10px 14px 18px;
    max-height: calc(100vh - 180px);
    overflow: auto;
}

.docs-nav__root,
.docs-nav__list,
.docs-toc__list,
.docs-breadcrumb__list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.docs-nav__item+.docs-nav__item,
.docs-nav__item--section+.docs-nav__item--section {
    margin-top: 6px;
}

.docs-nav__item--home {
    margin-bottom: 12px;
}

.docs-nav__section {
    position: relative;
}

.docs-nav__section-head {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 38px;
}

.docs-nav__toggle {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--docs-text);
    font: inherit;
    cursor: pointer;
    width: 24px;
    height: 24px;
    padding: 0;
    border-radius: 6px;
}

.docs-nav__toggle:hover,
.docs-nav__link:hover,
.docs-nav__section-link:hover {
    background: rgba(15, 23, 42, 0.04);
    text-decoration: none;
}

.docs-nav__toggle[aria-expanded="true"] .docs-nav__toggle-icon {
    transform: rotate(135deg);
}

.docs-nav__section-link,
.docs-nav__link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    width: 100%;
    padding: 7px 10px;
    border-radius: 10px;
    color: var(--docs-text-soft);
    line-height: 1.35;
    min-width: 0;
}

.docs-nav__section-link {
    font-weight: 600;
    color: var(--docs-text);
}

.docs-nav__section-label {
    display: inline-flex;
    align-items: center;
    width: 100%;
    min-width: 0;
    padding: 7px 10px;
    border-radius: 10px;
    color: var(--docs-text);
    font-weight: 600;
    line-height: 1.35;
}

.docs-nav__link.is-current,
.docs-nav__section-link.is-current {
    background: var(--docs-primary-soft);
    color: #9a3412;
    font-weight: 700;
}

.docs-nav__list {
    position: relative;
    margin-left: 11px;
    padding: 4px 0 0 18px;
}

.docs-nav__list::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 8px;
    left: 0;
    width: 1px;
    background: var(--docs-border);
}

.docs-nav__item--group {
    margin-top: 6px;
}

.docs-nav__item {
    position: relative;
}

.docs-nav__list>.docs-nav__item::before {
    content: "";
    position: absolute;
    top: 18px;
    left: -18px;
    width: 12px;
    height: 1px;
    background: var(--docs-border);
}

.docs-nav__list>.docs-nav__item:last-child::after {
    content: "";
    position: absolute;
    top: 19px;
    bottom: -8px;
    left: -19px;
    width: 3px;
    background: var(--docs-surface);
}

.docs-nav__item .docs-badge {
    flex: 0 0 auto;
    margin-left: auto;
}

.docs-breadcrumb {
    margin-bottom: 18px;
}

.docs-breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 0.95rem;
    color: var(--docs-text-muted);
}

.docs-breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.docs-breadcrumb__item+.docs-breadcrumb__item::before {
    content: "/";
    color: var(--docs-border-strong);
}

.docs-article {
    padding: 28px clamp(18px, 4vw, 40px);
}

.docs-page-header {
    margin-bottom: 24px;
}

.docs-page-header__eyebrow {
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--docs-text-muted);
    font-weight: 700;
}

.docs-page-header__title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 10px;
}

.docs-page-header__title {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1.08;
}

.docs-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
}

.docs-badge--pro {
    background: #111827;
    color: #fff;
}

.docs-content {
    font-size: 1rem;
    line-height: 1.75;
}

.docs-content hr {
    border: 0;
    border-top: 1px solid var(--docs-border);
    margin: 2rem 0;
}

.docs-content>*:first-child {
    margin-top: 0;
}

.docs-content h2,
.docs-content h3,
.docs-content h4,
.docs-content h5,
.docs-content h6 {
    scroll-margin-top: 100px;
    line-height: 1.2;
    margin-top: 2.2em;
    margin-bottom: 0.75em;
}

.docs-content h2 {
    font-size: 1.75rem;
}

.docs-content h3 {
    font-size: 1.32rem;
}

.docs-content p,
.docs-content ul,
.docs-content ol,
.docs-content blockquote,
.docs-content table,
.docs-content pre,
.docs-content figure {
    margin: 1.1em 0;
}

.docs-content ul,
.docs-content ol {
    padding-left: 1.4rem;
}

.docs-content li+li {
    margin-top: 0.35rem;
}

.docs-content table {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid var(--docs-border);
}

.docs-content th,
.docs-content td {
    border-bottom: 1px solid var(--docs-border);
    padding: 12px 14px;
    text-align: left;
    vertical-align: top;
}

.docs-content thead {
    background: var(--docs-surface-muted);
}

.docs-content blockquote {
    padding: 18px 20px;
    border-left: 4px solid var(--docs-primary);
    background: var(--docs-primary-soft);
    color: #7c2d12;
    border-radius: 14px;
}

.docs-content .contains-task-list {
    padding-left: 0;
    list-style: none;
}

.docs-content .task-list-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
}

.docs-content :not(pre)>code {
    padding: 0.2em 0.48em;
    border-radius: 8px;
    background: #eef2ff;
    color: #312e81;
    font-size: 0.92em;
}

.docs-content pre {
    position: relative;
    overflow: auto;
    padding: 18px;
    border-radius: 16px;
    background: #0f172a;
    color: #e2e8f0;
}

.docs-content pre code {
    background: transparent;
    color: inherit;
    padding: 0;
}

.docs-copy-button {
    position: absolute;
    top: 12px;
    right: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.08);
    color: #f8fafc;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 0.78rem;
    cursor: pointer;
}

.docs-copy-button:hover {
    background: rgba(255, 255, 255, 0.18);
}

.hljs-keyword,
.hljs-selector-tag,
.hljs-literal,
.hljs-title {
    color: #c084fc;
}

.hljs-string,
.hljs-attr,
.hljs-template-tag {
    color: #86efac;
}

.hljs-number,
.hljs-symbol,
.hljs-bullet {
    color: #fca5a5;
}

.hljs-comment,
.hljs-quote {
    color: #94a3b8;
}

.docs-figure {
    margin: 1.5rem 0;
}

.docs-figure img {
    display: block;
    width: auto;
    border: 1px solid var(--docs-border);
    border-radius: 16px;
    box-shadow: var(--docs-shadow);
    background: #fff;
}

.docs-figure figcaption {
    margin-top: 10px;
    font-size: 0.94rem;
    color: var(--docs-text-muted);
}

.docs-toc__item+.docs-toc__item {
    margin-top: 8px;
}

.docs-toc__item--level-3 {
    padding-left: 14px;
}

.docs-toc a {
    color: var(--docs-text-soft);
}

.docs-toc a.is-active {
    color: #9a3412;
    font-weight: 700;
}

.docs-home {
    display: grid;
    gap: 24px;
}

.docs-home__hero {
    padding: clamp(22px, 4vw, 34px);
    border-radius: 24px;
    background:
        radial-gradient(circle at top right, rgba(249, 115, 22, 0.17), transparent 28%),
        linear-gradient(135deg, #ffffff 0%, #fff7ed 100%);
    border: 1px solid rgba(249, 115, 22, 0.2);
}

.docs-home__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.06);
    color: var(--docs-text-soft);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.docs-home__hero h2 {
    margin: 16px 0 10px;
    font-size: clamp(2rem, 5vw, 3.1rem);
    line-height: 1.05;
}

.docs-home__hero p {
    max-width: 70ch;
    margin-bottom: 0;
    color: var(--docs-text-soft);
    font-size: 1.06rem;
}

.docs-home__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
}

.docs-home__actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 16px;
    border-radius: 999px;
    border: 1px solid rgba(15, 90, 217, 0.16);
    background: #fff;
    color: #0f5ad9;
    font-weight: 700;
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.04);
}

.docs-home__actions a:first-child {
    background: #0f172a;
    border-color: #0f172a;
    color: #fff;
}

.docs-home__actions a:hover {
    text-decoration: none;
    transform: translateY(-1px);
}

.docs-home__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
}

.docs-home__card {
    padding: 22px;
    border-radius: 20px;
    border: 1px solid var(--docs-border);
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
}

.docs-home__card h3 {
    margin: 0 0 10px;
    font-size: 1.15rem;
}

.docs-home__card p {
    margin: 0 0 12px;
    color: var(--docs-text-soft);
}

.docs-home__card ul {
    margin-bottom: 0;
}

.docs-home__card li+li {
    margin-top: 0.45rem;
}

.docs-toc__empty {
    color: var(--docs-text-muted);
    font-size: 0.95rem;
}

.docs-footer {
    padding: 20px 0 36px;
}

.docs-footer__inner {
    padding: 0 0 8px;
    color: var(--docs-text-muted);
    text-align: center;
}

.docs-sidebar-open {
    overflow: hidden;
}

@media (max-width: 1023px) {
    .docs-shell {
        grid-template-columns: minmax(0, 1fr) minmax(220px, 260px);
    }

    .docs-shell__sidebar {
        position: fixed;
        top: 72px;
        left: 16px;
        bottom: 16px;
        width: min(360px, calc(100vw - 32px));
        z-index: 40;
        transform: translateX(-120%);
        transition: transform 0.2s ease;
    }

    .docs-shell__overlay {
        position: fixed;
        inset: 0;
        z-index: 35;
        display: block;
        border: 0;
        background: rgba(15, 23, 42, 0.36);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
    }

    .docs-sidebar-open .docs-shell__sidebar {
        transform: translateX(0);
    }

    .docs-sidebar-open .docs-shell__overlay {
        opacity: 1;
        pointer-events: auto;
    }

    .docs-header__menu-button {
        display: inline-flex;
    }
}

@media (max-width: 767px) {
    .docs-shell {
        grid-template-columns: minmax(0, 1fr);
    }

    .docs-shell__toc,
    .docs-toc-panel {
        position: static;
    }

    .docs-header__tagline {
        display: none;
    }

    .docs-header__skip-link {
        display: none;
    }

    .docs-header__home img,
    .docs-header__home svg {
        width: 128px;
    }

    .docs-home__grid {
        grid-template-columns: minmax(0, 1fr);
    }

    .docs-home__actions {
        flex-direction: column;
    }

    .docs-home__actions a {
        width: 100%;
    }
}

@media (prefers-reduced-motion: reduce) {

    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 0.01ms !important;
    }
}

@media print {

    .docs-header,
    .docs-shell__sidebar,
    .docs-shell__toc,
    .docs-footer,
    .docs-copy-button {
        display: none !important;
    }

    .docs-shell {
        width: 100%;
        margin: 0;
        display: block;
    }

    .docs-article {
        box-shadow: none;
        border: 0;
        padding: 0;
    }
}